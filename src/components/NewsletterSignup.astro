---
/**
 * Newsletter signup — captures emails through the site's form backend (Netlify Forms
 * on Netlify; a FormSubmit endpoint on hosts without one, e.g. GitHub Pages).
 * Submissions land in the artist's Netlify dashboard or inbox; they can wire it to
 * Buttondown/Mailchimp via customCode if they want automation. Owning an audience
 * list is the most durable thing an independent artist can do, so it's one toggle.
 */
import { hostConfig } from '../lib/host';

interface Props {
  heading?: string;
  blurb?: string;
}
const { heading, blurb } = Astro.props;
const { useNetlifyForms, formEndpoint } = hostConfig();
---

<section class="ez-newsletter" aria-label="Newsletter signup">
  <div class="ez-newsletter__inner">
    <h2 class="ez-newsletter__title">{heading || 'Stay in the loop'}</h2>
    {blurb && <p class="ez-newsletter__blurb">{blurb}</p>}
    <form
      name="newsletter"
      method="POST"
      action={useNetlifyForms ? '/?subscribed=1' : formEndpoint}
      class="ez-newsletter__form"
      {...(useNetlifyForms ? { 'data-netlify': 'true', 'netlify-honeypot': 'bot-field' } : {})}
    >
      {useNetlifyForms ? (
        <>
          <input type="hidden" name="form-name" value="newsletter" />
          <p class="ez-visually-hidden" aria-hidden="true">
            <label>Do not fill this out: <input name="bot-field" /></label>
          </p>
        </>
      ) : (
        <>
          <input type="hidden" name="_subject" value="New newsletter signup" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="text" name="_honey" class="ez-visually-hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
        </>
      )}
      <label class="ez-visually-hidden" for="newsletter-email">Email address</label>
      <input
        class="ez-input ez-newsletter__email"
        id="newsletter-email"
        type="email"
        name="email"
        placeholder="you@example.com"
        autocomplete="email"
        required
      />
      <button type="submit" class="ez-btn ez-btn--primary">Subscribe</button>
    </form>
  </div>
</section>

<style>
  .ez-newsletter {
    border-top: var(--ez-border-width) solid var(--ez-border);
    margin-top: var(--ez-space-7);
    padding-top: var(--ez-space-6);
  }
  .ez-newsletter__inner { max-width: 520px; }
  .ez-newsletter__title { margin: 0 0 var(--ez-space-2); }
  .ez-newsletter__blurb { color: var(--ez-stone); margin: 0 0 var(--ez-space-4); }
  .ez-newsletter__form {
    display: flex;
    gap: var(--ez-space-3);
    flex-wrap: wrap;
  }
  .ez-newsletter__email { flex: 1 1 16rem; }
</style>
