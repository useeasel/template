---
import MotionToggle from './MotionToggle.astro';

interface Props {
  logoText: string;
  logo?: { mode: 'none' | 'text' | 'image'; image?: string };
  layout?: 'side' | 'top';
  pages?: { about: boolean; contact: boolean; cv: boolean; press: boolean };
}
const {
  logoText,
  logo = { mode: 'none' },
  layout = 'side',
  pages = { about: true, contact: true, cv: true, press: true },
} = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const all = [
  { href: '/', label: 'Work', on: true },
  { href: '/about', label: 'About', on: pages.about },
  { href: '/cv', label: 'CV', on: pages.cv },
  { href: '/press', label: 'Press', on: pages.press },
  { href: '/contact', label: 'Contact', on: pages.contact },
];
const links = all.filter((l) => l.on);
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<header class:list={['ez-nav', `ez-nav--${layout}`]}>
  <div class="ez-container ez-nav__inner">
    <a href="/" class="ez-nav__brand" aria-label={`${logoText} — home`}>
      {logo.mode === 'image' && logo.image ? (
        <img class="ez-nav__logoimg" src={logo.image} alt={logoText} />
      ) : (
        <span class="ez-nav__logotext">{logoText}</span>
      )}
    </a>

    <nav aria-label="Primary">
      <ul class="ez-nav__list">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['ez-nav__link', { 'is-active': isActive(link.href) }]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="ez-nav__tools">
      <MotionToggle />
    </div>
  </div>
</header>

<style>
  .ez-nav {
    background: var(--ez-paper);
    border-bottom: var(--ez-border-width) solid var(--ez-border);
  }
  .ez-nav__inner {
    display: flex;
    align-items: center;
    gap: var(--ez-space-5);
    padding-block: var(--ez-space-4);
    flex-wrap: wrap;
  }
  .ez-nav__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--ez-space-3);
    text-decoration: none;
    color: var(--ez-ink);
    margin-right: auto;
  }
  .ez-nav__logotext {
    font-family: var(--ez-font-display);
    font-weight: var(--ez-heading-weight, 800);
    font-size: var(--ez-text-xl);
    letter-spacing: var(--ez-heading-spacing, -0.02em);
    text-transform: var(--ez-heading-transform, none);
  }
  .ez-nav__logoimg { max-height: 44px; width: auto; }
  .ez-nav__list {
    display: flex;
    gap: var(--ez-space-5);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .ez-nav__link {
    font-family: var(--ez-font-display);
    font-weight: 700;
    text-decoration: none;
    color: var(--ez-ink);
    padding-bottom: 2px;
    border-bottom: var(--ez-border-width) solid transparent;
  }
  .ez-nav__link:hover { border-bottom-color: var(--ez-ink); }
  .ez-nav__link.is-active { border-bottom-color: var(--ez-blue); color: var(--ez-blue); }
  .ez-nav__tools { display: flex; align-items: center; }

  /* Top layout: name on its own row, centered, with the links centered below. */
  .ez-nav--top .ez-nav__inner {
    flex-direction: column;
    align-items: center;
    gap: var(--ez-space-3);
    text-align: center;
  }
  .ez-nav--top .ez-nav__brand { margin-right: 0; }
  .ez-nav--top .ez-nav__tools { position: absolute; right: var(--ez-space-5); top: var(--ez-space-4); }
  .ez-nav--top { position: relative; }

  @media (max-width: 640px) {
    .ez-nav__inner { gap: var(--ez-space-3); }
    .ez-nav__list { gap: var(--ez-space-4); font-size: var(--ez-text-sm); }
  }
</style>
