---
/**
 * Masonry — a CSS-columns portfolio layout. Mirrors Grid.astro but starts in
 * masonry mode. Both share the `data-ez-portfolio` container and the same
 * `data-layout` styles so the LayoutToggle can swap between them at runtime.
 */
interface Props {
  columns?: number;
}
const { columns = 3 } = Astro.props;
---

<div
  class="ez-portfolio"
  data-ez-portfolio
  data-layout="masonry"
  style={`--ez-columns:${columns}`}
>
  <slot />
</div>

<style>
  .ez-portfolio {
    --ez-columns: 3;
  }
  .ez-portfolio[data-layout='masonry'] {
    column-count: var(--ez-columns);
    column-gap: var(--ez-gap);
  }
  .ez-portfolio[data-layout='masonry'] > :global(*) {
    break-inside: avoid;
    margin-bottom: var(--ez-gap);
  }
  .ez-portfolio[data-layout='grid'] {
    display: grid;
    grid-template-columns: repeat(var(--ez-columns), 1fr);
    gap: var(--ez-gap);
  }

  @media (max-width: 1024px) {
    .ez-portfolio[data-layout='masonry'] { column-count: 2; }
    .ez-portfolio[data-layout='grid'] { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .ez-portfolio[data-layout='masonry'] { column-count: 1; }
    .ez-portfolio[data-layout='grid'] { grid-template-columns: 1fr; }
  }
</style>
