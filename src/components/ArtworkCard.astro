---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import StatusPill from './StatusPill.astro';
import { CARD_WIDTHS, cardSizes } from '../lib/images';

interface Props {
  image: ImageMetadata;
  title: string;
  alt: string;
  year?: number;
  medium?: string;
  dimensions?: string;
  price?: string;
  status: 'available' | 'sold' | 'inquire' | 'nfs';
  columns?: number;
  /** Index used for the lightbox gallery. */
  index?: number;
  /** When set, the card links to this URL (its own page) instead of the lightbox. */
  href?: string;
  /** Series slug this piece belongs to — drives the home gallery filter chips. */
  series?: string;
}
const {
  image,
  title,
  alt,
  year,
  medium,
  dimensions,
  price,
  status,
  columns = 3,
  index,
  href,
  series,
} = Astro.props;

const metaParts = [year, medium, dimensions].filter(Boolean);

// Same trigger element, two behaviors: a link to the artwork's own page, or a
// button that opens the lightbox. A dynamic tag keeps the image markup in one place.
const Trigger = href ? 'a' : 'button';
const triggerProps = href
  ? { href, class: 'ez-artcard__trigger ez-artcard__trigger--link', 'aria-label': `View ${title}` }
  : {
      type: 'button',
      class: 'ez-artcard__trigger',
      'data-ez-lightbox': true,
      'data-index': index,
      'aria-label': `View ${title}`,
    };
---

<article class="ez-card ez-artcard" data-status={status} data-series={series}>
  <Trigger {...triggerProps}>
    <Image
      src={image}
      alt={alt}
      widths={CARD_WIDTHS}
      sizes={cardSizes(columns)}
      loading="lazy"
      class="ez-artcard__img"
    />
  </Trigger>

  <div class="ez-artcard__body">
    <div class="ez-artcard__head">
      <h3 class="ez-artcard__title">{title}</h3>
      <StatusPill status={status} />
    </div>
    {metaParts.length > 0 && (
      <p class="ez-artcard__meta">{metaParts.join(' · ')}</p>
    )}
    {status === 'available' && price && (
      <p class="ez-artcard__price">{price}</p>
    )}
  </div>
</article>

<style>
  .ez-artcard {
    overflow: hidden;
    background: var(--ez-white);
    transition: transform var(--ez-motion-base) var(--ez-ease);
  }
  .ez-artcard__trigger {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    border-bottom: var(--ez-border-width) solid var(--ez-border);
    background: var(--ez-paper);
    cursor: zoom-in;
    overflow: hidden;
    /* Round the top corners to match the card so the image (and its hover zoom)
       clip cleanly instead of poking square corners past the rounded border. */
    border-radius: var(--ez-radius) var(--ez-radius) 0 0;
  }
  .ez-artcard__trigger--link { cursor: pointer; }
  .ez-artcard__img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform var(--ez-motion-base) var(--ez-ease);
  }
  /* Hover + crop are driven by root classes from the design tokens (see tokens.css). */
  .ez-artcard__body {
    padding: var(--ez-space-4);
  }
  .ez-artcard__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--ez-space-3);
  }
  .ez-artcard__title {
    font-size: var(--ez-text-lg);
    margin: 0;
  }
  .ez-artcard__meta {
    margin: var(--ez-space-2) 0 0;
    color: var(--ez-stone);
    font-size: var(--ez-text-sm);
  }
  .ez-artcard__price {
    margin: var(--ez-space-2) 0 0;
    font-family: var(--ez-font-display);
    font-weight: 700;
    color: var(--ez-blue);
  }
</style>
