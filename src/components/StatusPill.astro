---
/**
 * StatusPill — the only fully-rounded element in the system. Color encodes the
 * artwork's status (available=blue, sold=red, inquire=yellow, nfs=stone).
 */
type Status = 'available' | 'sold' | 'inquire' | 'nfs';

interface Props {
  status: Status;
  class?: string;
}
const { status, class: className } = Astro.props;

const labels: Record<Status, string> = {
  available: 'Available',
  sold: 'Sold',
  inquire: 'Inquire',
  nfs: 'Not for sale',
};
---

<span class:list={['ez-pill', `ez-pill--${status}`, className]}>{labels[status]}</span>

<style>
  .ez-pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--ez-font-display);
    font-weight: 700;
    font-size: var(--ez-text-xs);
    letter-spacing: 0.02em;
    line-height: 1;
    padding: 0.4em 0.85em;
    border: var(--ez-border-width) solid var(--ez-border);
    border-radius: var(--ez-radius-pill); /* pills are the rounded exception */
    color: var(--ez-white);
  }
  .ez-pill--available { background: var(--ez-status-available); }
  .ez-pill--sold { background: var(--ez-status-sold); }
  /* yellow needs ink text for contrast */
  .ez-pill--inquire { background: var(--ez-status-inquire); color: var(--ez-ink); }
  .ez-pill--nfs { background: var(--ez-status-nfs); }
</style>
