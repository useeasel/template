---
/**
 * Lightbox — a dark (--ez-ink) overlay gallery. Driven by clicks on any element
 * with [data-ez-lightbox]; reads the gallery contents from a JSON payload the
 * page provides via the `items` prop. Supports:
 *   - keyboard: Esc closes, Left/Right navigate
 *   - basic swipe (touch) navigation
 *   - a gallery label showing the artwork metadata
 */
interface LightboxItem {
  src: string;
  alt: string;
  title: string;
  meta?: string;
  status?: string;
}
interface Props {
  items: LightboxItem[];
}
const { items } = Astro.props;
---

<div
  class="ez-lightbox"
  data-ez-lightbox-root
  role="dialog"
  aria-modal="true"
  aria-label="Artwork viewer"
  hidden
>
  <div class="ez-lightbox__bar">
    <button type="button" class="ez-btn ez-btn--icon ez-btn--ghost ez-lightbox__close" data-ez-lb-close aria-label="Close viewer">
      <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 5l14 14M19 5L5 19" /></svg>
    </button>
  </div>

  <button type="button" class="ez-lightbox__nav ez-lightbox__nav--prev" data-ez-lb-prev aria-label="Previous artwork">
    <svg width="28" height="28" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 6l-6 6 6 6" /></svg>
  </button>

  <figure class="ez-lightbox__stage">
    <img class="ez-lightbox__img" data-ez-lb-img alt="" />
    <figcaption class="ez-lightbox__label" data-ez-lb-label>
      <span class="ez-lightbox__title" data-ez-lb-title></span>
      <span class="ez-lightbox__meta" data-ez-lb-meta></span>
    </figcaption>
  </figure>

  <button type="button" class="ez-lightbox__nav ez-lightbox__nav--next" data-ez-lb-next aria-label="Next artwork">
    <svg width="28" height="28" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6" /></svg>
  </button>
</div>

<script type="application/json" data-ez-lb-data set:html={JSON.stringify(items)}></script>

<style>
  .ez-lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: var(--ez-ink);
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto 1fr;
    align-items: center;
    color: var(--ez-white);
  }
  .ez-lightbox[hidden] { display: none; }

  .ez-lightbox__bar {
    grid-column: 1 / -1;
    display: flex;
    justify-content: flex-end;
    padding: var(--ez-space-4);
  }
  .ez-lightbox__close,
  .ez-lightbox__nav {
    color: var(--ez-white);
  }
  .ez-lightbox__nav {
    background: transparent;
    border: var(--ez-border-width) solid var(--ez-white);
    border-radius: var(--ez-radius);
    width: 3rem;
    height: 3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    margin: var(--ez-space-4);
  }
  .ez-lightbox__nav:hover {
    background: var(--ez-white);
    color: var(--ez-ink);
  }
  .ez-lightbox__stage {
    grid-row: 2;
    grid-column: 2;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--ez-space-4);
    padding: var(--ez-space-4);
    max-height: 100%;
    overflow: hidden;
  }
  .ez-lightbox__img {
    max-width: 100%;
    max-height: 70vh;
    object-fit: contain;
    border: var(--ez-border-width) solid var(--ez-white);
    background: var(--ez-white);
  }
  /* Click-to-zoom (only when the theme enables it). The stage clips the scaled
     image; transform-origin tracks the pointer so moving the mouse pans the view. */
  .ez-lightbox__img.ez-lb-zoomable { cursor: zoom-in; }
  .ez-lightbox__img.is-zoomed {
    cursor: zoom-out;
    transform: scale(2.6);
    transition: none;
  }
  .ez-lightbox__label {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--ez-space-1);
  }
  .ez-lightbox__title {
    font-family: var(--ez-font-display);
    font-weight: 700;
    font-size: var(--ez-text-xl);
  }
  .ez-lightbox__meta {
    color: var(--ez-stone);
    font-size: var(--ez-text-sm);
  }

  @media (max-width: 640px) {
    .ez-lightbox__nav {
      width: 2.5rem;
      height: 2.5rem;
      margin: var(--ez-space-2);
    }
  }
</style>

<script>
  type Item = { src: string; alt: string; title: string; meta?: string };

  const root = document.querySelector<HTMLElement>('[data-ez-lightbox-root]');
  const dataEl = document.querySelector<HTMLScriptElement>('[data-ez-lb-data]');
  if (root && dataEl) {
    const items: Item[] = JSON.parse(dataEl.textContent || '[]');
    const img = root.querySelector<HTMLImageElement>('[data-ez-lb-img]')!;
    const titleEl = root.querySelector<HTMLElement>('[data-ez-lb-title]')!;
    const metaEl = root.querySelector<HTMLElement>('[data-ez-lb-meta]')!;
    let current = 0;
    let lastFocused: HTMLElement | null = null;

    // Click-to-zoom, only when the theme turns it on (root class ez-lbzoom).
    const zoomOn = document.documentElement.classList.contains('ez-lbzoom');
    let zoomed = false;
    const setZoom = (on: boolean) => {
      zoomed = on;
      img.classList.toggle('is-zoomed', on);
      if (!on) img.style.transformOrigin = 'center center';
    };

    const render = () => {
      const item = items[current];
      if (!item) return;
      if (zoomOn) setZoom(false); // reset zoom whenever the image changes
      img.src = item.src;
      img.alt = item.alt;
      titleEl.textContent = item.title;
      metaEl.textContent = item.meta ?? '';
      // Restart the entrance animation (fade/slide, chosen by the theme).
      img.classList.remove('ez-anim');
      void img.offsetWidth;
      img.classList.add('ez-anim');
    };

    if (zoomOn) {
      img.classList.add('ez-lb-zoomable');
      img.addEventListener('click', (e) => {
        e.stopPropagation(); // don't bubble to the backdrop-close handler
        setZoom(!zoomed);
      });
      img.addEventListener('mousemove', (e) => {
        if (!zoomed) return;
        const r = img.getBoundingClientRect();
        const x = ((e.clientX - r.left) / r.width) * 100;
        const y = ((e.clientY - r.top) / r.height) * 100;
        img.style.transformOrigin = `${Math.max(0, Math.min(100, x))}% ${Math.max(0, Math.min(100, y))}%`;
      });
    }

    const open = (index: number) => {
      current = index;
      lastFocused = document.activeElement as HTMLElement;
      render();
      root.hidden = false;
      document.body.style.overflow = 'hidden';
      root.querySelector<HTMLButtonElement>('[data-ez-lb-close]')?.focus();
    };

    const close = () => {
      root.hidden = true;
      document.body.style.overflow = '';
      lastFocused?.focus();
    };

    const go = (delta: number) => {
      current = (current + delta + items.length) % items.length;
      render();
    };

    document.querySelectorAll<HTMLElement>('[data-ez-lightbox]').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const idx = Number(trigger.dataset.index ?? '0');
        open(Number.isNaN(idx) ? 0 : idx);
      });
    });

    root.querySelector('[data-ez-lb-close]')?.addEventListener('click', close);
    root.querySelector('[data-ez-lb-prev]')?.addEventListener('click', () => go(-1));
    root.querySelector('[data-ez-lb-next]')?.addEventListener('click', () => go(1));

    root.addEventListener('click', (e) => {
      if (e.target === root) close();
    });

    document.addEventListener('keydown', (e) => {
      if (root.hidden) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') go(-1);
      if (e.key === 'ArrowRight') go(1);
    });

    // Basic swipe support.
    let startX = 0;
    root.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
    root.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 40) go(dx < 0 ? 1 : -1);
    }, { passive: true });
  }
</script>
