---
/**
 * Living style guide for the Easel Bauhaus system. Mirrors the approved component
 * spec so you can see tokens + components in the browser and tweak them. Not part
 * of the public nav — visit /styleguide directly.
 */
import Base from '../layouts/Base.astro';
import EaselMark from '../components/EaselMark.astro';
import StatusPill from '../components/StatusPill.astro';

const swatches = [
  { name: 'Blue · primary', var: '--ez-blue', hex: '#1D4ED8' },
  { name: 'Red · accent', var: '--ez-red', hex: '#E63946' },
  { name: 'Yellow · highlight', var: '--ez-yellow', hex: '#F4C20D' },
  { name: 'Ink · text', var: '--ez-ink', hex: '#161616' },
  { name: 'Paper · bg', var: '--ez-paper', hex: '#F7F4EC' },
  { name: 'White · surface', var: '--ez-white', hex: '#FFFFFF' },
  { name: 'Stone · muted', var: '--ez-stone', hex: '#6B6B63' },
];
const statuses = ['available', 'sold', 'inquire', 'nfs'] as const;
---

<Base pageTitle="Style guide" pageDescription="Easel Bauhaus component system">
  <div class="ez-container sg">
    <header class="sg-head">
      <EaselMark size={56} />
      <div>
        <h1>Style guide</h1>
        <p class="sg-sub">The Bauhaus component system that powers this template.</p>
      </div>
    </header>

    <section class="sg-sec">
      <h2 class="sg-lab">Color tokens</h2>
      <div class="sg-swatches">
        {swatches.map((s) => (
          <div class="sg-swatch">
            <div class="sg-chip" style={`background: var(${s.var})`}></div>
            <div class="sg-chip-name">{s.name}</div>
            <code class="sg-hex">{s.hex}</code>
          </div>
        ))}
      </div>
    </section>

    <section class="sg-sec">
      <h2 class="sg-lab">Typography</h2>
      <div class="sg-type">
        <div><span class="sg-cap">Display · Syne</span><div class="sg-display">easel</div></div>
        <div><span class="sg-cap">H2</span><h2 class="sg-h2">Recent works, 2024</h2></div>
        <div><span class="sg-cap">Body · Space Grotesk</span><p class="sg-body">A painter working between Lisbon and Berlin, exploring colour, edge, and the line between order and accident.</p></div>
        <div><span class="sg-cap">Label / caption</span><div class="sg-caption">Oil on linen · 90 × 120 cm · 2024</div></div>
      </div>
    </section>

    <section class="sg-sec">
      <h2 class="sg-lab">Logo &amp; motif</h2>
      <div class="sg-row">
        <div class="sg-stack"><span class="sg-cap">Horizontal lockup</span>
          <div class="sg-lockup"><EaselMark size={40} /><span class="sg-wordmark">easel</span></div>
        </div>
        <div class="sg-stack"><span class="sg-cap">Mark only</span><EaselMark size={48} /></div>
        <div class="sg-stack"><span class="sg-cap">Primitives</span>
          <div class="sg-prims">
            <span class="ez-shape ez-shape--circle" style="width:1.6rem;height:1.6rem"></span>
            <span class="ez-shape ez-shape--square" style="width:1.6rem;height:1.6rem"></span>
            <span class="ez-shape ez-shape--triangle" style="border-left-width:.8rem;border-right-width:.8rem;border-bottom-width:1.6rem"></span>
          </div>
        </div>
      </div>
    </section>

    <section class="sg-sec">
      <h2 class="sg-lab">Buttons</h2>
      <div class="sg-row">
        <div class="sg-stack"><span class="sg-cap">Primary</span><button class="ez-btn ez-btn--primary">Start free</button></div>
        <div class="sg-stack"><span class="sg-cap">Accent</span><button class="ez-btn ez-btn--accent">Publish</button></div>
        <div class="sg-stack"><span class="sg-cap">Outline</span><button class="ez-btn ez-btn--outline">View CV</button></div>
        <div class="sg-stack"><span class="sg-cap">Ghost</span><button class="ez-btn ez-btn--ghost">Cancel</button></div>
        <div class="sg-stack"><span class="sg-cap">Icon</span><button class="ez-btn ez-btn--icon" aria-label="Add">+</button></div>
      </div>
      <div class="sg-row" style="margin-top: var(--ez-space-5)">
        <div class="sg-stack"><span class="sg-cap">Small</span><button class="ez-btn ez-btn--primary ez-btn--sm">Edit</button></div>
        <div class="sg-stack"><span class="sg-cap">Medium</span><button class="ez-btn ez-btn--primary">Edit</button></div>
        <div class="sg-stack"><span class="sg-cap">Large</span><button class="ez-btn ez-btn--primary ez-btn--lg">Edit</button></div>
        <div class="sg-stack"><span class="sg-cap">Disabled</span><button class="ez-btn ez-btn--primary" disabled>Edit</button></div>
      </div>
    </section>

    <section class="sg-sec">
      <h2 class="sg-lab">Form fields</h2>
      <div class="sg-fields">
        <label class="ez-field"><span class="ez-label">Title</span><input class="ez-input" value="Untitled (no. 4)" /></label>
        <label class="ez-field"><span class="ez-label">Medium</span><select class="ez-select"><option>Oil on canvas</option><option>Gouache on paper</option></select></label>
        <label class="ez-field ez-field--error"><span class="ez-label">Alt text</span><input class="ez-input" aria-invalid="true" value="" /><span class="ez-error-text">Alt text is required</span></label>
      </div>
    </section>

    <section class="sg-sec">
      <h2 class="sg-lab">Status pills</h2>
      <div class="sg-row">
        {statuses.map((s) => <StatusPill status={s} />)}
      </div>
    </section>

    <section class="sg-sec">
      <h2 class="sg-lab">Artwork card &amp; lightbox label</h2>
      <div class="sg-row" style="align-items: flex-start">
        <div class="ez-card sg-artcard">
          <div class="sg-art-img"><span class="sg-art-c"></span><span class="sg-art-t"></span></div>
          <div class="sg-art-meta">
            <div class="sg-art-title">Composition IX</div>
            <div class="sg-caption">2024 · 80 × 100 cm</div>
            <StatusPill status="available" class="sg-art-pill" />
          </div>
        </div>
        <div class="sg-lightlabel">
          <div class="sg-ll-title">Composition IX</div>
          <div class="sg-ll-meta">Oil on linen, 2024<br />80 × 100 cm</div>
          <div class="sg-ll-cta">Inquire to purchase</div>
        </div>
      </div>
    </section>
  </div>
</Base>

<style>
  .sg { padding-block: var(--ez-space-6); }
  .sg-head { display: flex; align-items: center; gap: var(--ez-space-4); margin-bottom: var(--ez-space-8); }
  .sg-sub { color: var(--ez-stone); margin: 0; }
  .sg-sec { padding-block: var(--ez-space-6); border-top: var(--ez-border-width) solid var(--ez-border); }
  .sg-lab {
    font-family: var(--ez-font-display); font-weight: 700; font-size: var(--ez-text-sm);
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--ez-blue);
    display: flex; align-items: center; gap: var(--ez-space-2); margin-bottom: var(--ez-space-5);
  }
  .sg-lab::before { content: ''; width: 0.85rem; height: 0.85rem; background: var(--ez-red); display: inline-block; }
  .sg-row { display: flex; flex-wrap: wrap; gap: var(--ez-space-5); align-items: center; }
  .sg-stack { display: flex; flex-direction: column; gap: var(--ez-space-2); }
  .sg-cap { font-size: var(--ez-text-xs); color: var(--ez-stone); font-weight: 500; }
  .sg-swatches { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: var(--ez-space-4); }
  .sg-swatch { display: flex; flex-direction: column; gap: var(--ez-space-2); }
  .sg-chip { height: 4rem; border: var(--ez-border-width) solid var(--ez-border); }
  .sg-chip-name { font-weight: 700; font-size: var(--ez-text-sm); }
  .sg-hex { font-size: var(--ez-text-xs); color: var(--ez-stone); }
  .sg-type > div { margin-bottom: var(--ez-space-5); }
  .sg-display { font-family: var(--ez-font-display); font-weight: 700; font-size: var(--ez-text-4xl); line-height: 1; }
  .sg-h2 { margin: 0; }
  .sg-body { max-width: 60ch; margin: 0; }
  .sg-caption { font-size: var(--ez-text-xs); font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ez-stone); }
  .sg-lockup { display: flex; align-items: center; gap: var(--ez-space-3); }
  .sg-wordmark { font-family: var(--ez-font-display); font-weight: 700; font-size: var(--ez-text-2xl); }
  .sg-prims { display: flex; align-items: flex-end; gap: var(--ez-space-3); }
  .sg-fields { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--ez-space-5); max-width: 720px; }
  .sg-artcard { width: 220px; }
  .sg-art-img { position: relative; height: 160px; background: var(--ez-blue); border-bottom: var(--ez-border-width) solid var(--ez-border); }
  .sg-art-c { position: absolute; left: 16px; top: 16px; width: 38px; height: 38px; border-radius: 50%; background: var(--ez-yellow); }
  .sg-art-t { position: absolute; right: 0; bottom: 0; width: 0; height: 0; border-left: 44px solid transparent; border-bottom: 44px solid var(--ez-red); }
  .sg-art-meta { padding: var(--ez-space-3) var(--ez-space-4); display: flex; flex-direction: column; gap: var(--ez-space-2); }
  .sg-art-title { font-family: var(--ez-font-display); font-weight: 700; font-size: var(--ez-text-lg); }
  .sg-art-pill { align-self: flex-start; }
  .sg-lightlabel { background: var(--ez-ink); color: var(--ez-white); padding: var(--ez-space-5); max-width: 260px; }
  .sg-ll-title { font-family: var(--ez-font-display); font-weight: 700; font-size: var(--ez-text-xl); }
  .sg-ll-meta { color: #c9c6bd; font-size: var(--ez-text-sm); margin-top: var(--ez-space-2); line-height: 1.5; }
  .sg-ll-cta { color: var(--ez-yellow); font-weight: 700; font-size: var(--ez-text-xs); letter-spacing: 0.06em; text-transform: uppercase; margin-top: var(--ez-space-3); }
</style>
